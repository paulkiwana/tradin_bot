# ============================================
# Crypto Monitor Configuration
# ============================================

# MODE SELECTION:
# - Manual Mode: Specify exact symbols below (CRYPTO_SYMBOLS)
# - Auto Mode: Leave CRYPTO_SYMBOLS empty to auto-discover all symbols

# Cryptocurrency symbols to monitor (comma-separated)
# Examples: BTC/USDT, ETH/USDT, SOL/USDT, DOGE/USDT, ADA/USDT
# Leave empty or comment out to enable AUTO-DISCOVERY mode
CRYPTO_SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT

# ============================================
# Auto-Discovery Settings (for auto mode)
# ============================================

# Quote currencies to monitor (comma-separated)
# The app will find all coins paired with these currencies
# Examples: USDT, USD, BTC, ETH, BUSD, USDC
QUOTE_CURRENCIES=USDT,USD,BTC,ETH

# Minimum 24-hour trading volume (in quote currency)
# Filters out low-volume/illiquid coins
# 1000000 = $1 million (recommended)
# 500000 = $500k (more symbols)
# 5000000 = $5 million (fewer, higher quality symbols)
MIN_VOLUME_24H=1000000

# Maximum number of symbols to monitor
# Prevents overload and rate limiting
# 50 = Conservative (recommended for 5-min intervals)
# 100 = Moderate (may need 10-min intervals)
# 200 = Aggressive (requires 15-min+ intervals)
MAX_SYMBOLS=100

# How often to refresh the symbol list (in hours)
# New coins are added, old coins delisted
# 24 = Daily refresh (recommended)
# 6 = Every 6 hours (more frequent)
# 168 = Weekly refresh
REFRESH_SYMBOLS_HOURS=24

# Minimum price filter (avoid extremely low-priced coins)
# 0.000001 = Very inclusive
# 0.01 = Filter out sub-penny coins
MIN_PRICE=0.000001

# Exchange to use
# Supported: binance, coinbase, kraken, kucoin, bybit, etc.
# See https://github.com/ccxt/ccxt for full list
EXCHANGE=bybit

# Check interval in seconds
# 300 = 5 minutes (recommended)
# 600 = 10 minutes (safer for rate limits)
# 60 = 1 minute (may hit rate limits)
CHECK_INTERVAL=300

# RSI Thresholds
# RSI_OVERBOUGHT: Alert when RSI is ABOVE this value (oversold condition)
# Default: 90 (very extreme), try 80 for more alerts
RSI_OVERBOUGHT=90

# RSI_OVERSOLD: Alert when RSI is BELOW this value (overbought condition)
# Default: 10 (very extreme), try 20 for more alerts
RSI_OVERSOLD=10

# Support/Resistance detection sensitivity
# This is the percentage threshold for price proximity to S/R levels
# 0.02 = 2% (default - balanced)
# 0.01 = 1% (stricter - fewer alerts, more precise)
# 0.03 = 3% (looser - more alerts, less precise)
SR_THRESHOLD=0.02
